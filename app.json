{
  "expo": {
    "name": "Cielo App",
    "slug": "cielo-app",
    "scheme": "cieloapp",
    "version": "0.7.7",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Usar cámara para escanear QR de sincronización entre dispositivos"
      },
      "bundleIdentifier": "com.buscer.cieloapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.buscer.cieloapp",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.INTERNET"
      ]
    },
    "newArchEnabled": true,
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-sqlite",
        {
          "useLibSQL": false,
          "withSQLiteVecExtension": false
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "android": {
            "abiFilters": [
              "arm64-v8a",
              "armeabi-v7a"
            ],
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "newArchEnabled": true,
            "useLegacyPackaging": true,
            "googleServicesFile": "./google-services.json"
          },
          "ios": {
            "newArchEnabled": true,
            "googleServicesFile": "./GoogleService-Info.plist"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Usar cámara para escanear QR de sincronización"
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "4130a34c-00de-4081-859a-25395a78efe2"
      }
    }
  }
}